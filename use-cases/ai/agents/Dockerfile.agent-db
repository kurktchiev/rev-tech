FROM python:3.13-slim-bookworm

# Install tsh for database discovery via Teleport
RUN apt-get update && apt-get install -y --no-install-recommends curl && \
    curl -L https://goteleport.com/static/install.sh | bash -s -- 18.6.4 && \
    apt-get clean && rm -rf /var/lib/apt/lists/* && \
    tsh version

# Install uv for fast package management
RUN pip install --no-cache-dir uv

WORKDIR /app

# Copy shared package files and agent_db code
COPY pyproject.toml ./
COPY __init__.py ./agents/
COPY base_agent/ ./agents/base_agent/
COPY agent_db/ ./agents/agent_db/
COPY teleport/ ./agents/teleport/

# Install dependencies (includes psycopg2-binary from agent_db)
RUN uv pip install --system . psycopg2-binary

EXPOSE 8080

CMD ["python", "-m", "agents.agent_db.main"]
