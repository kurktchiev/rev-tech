FROM python:3.13-slim-bookworm

# Install tsh for SSH access via Teleport
RUN apt-get update && apt-get install -y --no-install-recommends curl && \
    curl -L https://goteleport.com/static/install.sh | bash -s -- 18.6.4 && \
    apt-get clean && rm -rf /var/lib/apt/lists/* && \
    tsh version

# Install uv for fast package management
RUN pip install --no-cache-dir uv

WORKDIR /app

# Copy shared package files and agent_ssh code
COPY pyproject.toml ./
COPY __init__.py ./agents/
COPY base_agent/ ./agents/base_agent/
COPY agent_ssh/ ./agents/agent_ssh/
COPY teleport/ ./agents/teleport/

# Install dependencies
RUN uv pip install --system .

EXPOSE 8080

CMD ["python", "-m", "agents.agent_ssh.main"]
