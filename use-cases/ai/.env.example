# .env
# LLM selection
LLM_PROVIDER=anthropic          # or: ollama, lmstudio

# Anthropic
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
OLLAMA_PORT=11434
OLLAMA_CHAT_COMPLETION_URL=http://ollama:11434/v1/chat/completions

# LM Studio
LM_STUDIO_MODEL=qwen/qwen3-vl-4b
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_API_KEY=lm-studio     # any non-empty string

# Chainlit
# RUN (openssl rand -hex 32) for a secret
CHAINLIT_AUTH_SECRET=None
CHAINLIT_PORT=8000
