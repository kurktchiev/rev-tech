# .env

# Required
TELEPORT_PROXY=teleport.yourdomain.com

# LLM selection
LLM_PROVIDER=anthropic          # or: ollama, openai


# Orchestrator Config
ORCHESTRATOR_LLM_PROVIDER=${LLM_PROVIDER}
ORCHESTRATOR_PORT=9000
ORCHESTRATOR_AGENTS_CONFIG=orchestrator/agents.json
ORCHESTRATOR_TSH_DISCOVERY_QUERY='labels["app-type"] == "specialist" && labels["demo"] == "ai-agents"'

# General Knowledge Agent Config
GENERAL_AGENT_LLM_PROVIDER=${LLM_PROVIDER}
GENERAL_AGENT_PORT=9003

ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...

OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://host.docker.internal:11434

OPENAI_API_KEY=sk-...           # or any non-empty string for local servers
OPENAI_BASE_URL=http://host.docker.internal:1234/v1  # LM Studio, vLLM, etc.
OPENAI_MODEL=gpt-4o

# Chainlit
CHAINLIT_CHAT_MODEL=qwen2.5:0.5b-instruct
CHAINLIT_CHAT_COMPLETION_URL=http://ollama:11434/v1/chat/completions
CHAINLIT_PORT=8000

# Teleport — TELEPORT_PROXY is read by tsh automatically
# Set TELEPORT_CLUSTER only if targeting a leaf cluster (defaults to proxy)
# TELEPORT_CLUSTER=leaf.yourdomain.com

# Operator (set in K8s manifest, not .env)
# --namespace=a2a-demo
# --agent-label=type=agent
# --orchestrator-url=http://orchestrator:8080
