# Join token for agent-db-bot
# DO NOT EDIT - use setup.sh to generate agent-db-bot-token.yaml from this template
kind: token
version: v2
metadata:
  name: agent-db-bot-k8s-join
spec:
  bot_name: agent-db-bot
  roles:
    - Bot
  join_method: kubernetes
  kubernetes:
    type: static_jwks
    allow:
      - service_account: "ai-agents:agent-db-tbot"
    static_jwks:
      jwks: 'PASTE_JWKS_HERE'
