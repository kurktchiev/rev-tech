# Join token for orchestrator-bot
# DO NOT EDIT - use setup.sh to generate orchestrator-bot-token.yaml from this template
kind: token
version: v2
metadata:
  name: orchestrator-bot-k8s-join
spec:
  bot_name: orchestrator-bot
  roles:
    - Bot
  join_method: kubernetes
  kubernetes:
    type: static_jwks
    allow:
      - service_account: "ai-agents:orchestrator-tbot"
    static_jwks:
      jwks: 'PASTE_JWKS_HERE'
