apiVersion: v1
kind: ServiceAccount
metadata:
  name: agent-ssh-tbot
  namespace: ai-agents
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: agent-ssh
  namespace: ai-agents
spec:
  replicas: 1
  selector:
    matchLabels:
      demo: ai-agents
      function: agent-ssh
  template:
    metadata:
      labels:
        demo: ai-agents
        function: agent-ssh
    spec:
      serviceAccountName: agent-ssh-tbot
      containers:
        # --- Agent SSH ---
        - name: agent-ssh
          image: ${AGENT_SSH_IMAGE}
          imagePullPolicy: IfNotPresent
          command: ["python", "-m", "agents.agent_ssh.main"]
          ports:
            - containerPort: 8080
          env:
            - name: AGENT_PORT
              value: "8080"
            - name: AGENT_SSH_MODE
              value: "tsh"
            - name: AGENT_SSH_USER
              value: "ubuntu"
            - name: LLM_PROVIDER
              value: "${LLM_PROVIDER}"
            - name: OPENAI_MODEL
              value: "${OPENAI_MODEL}"
            - name: OPENAI_BASE_URL
              value: "${OPENAI_BASE_URL}"
            - name: OPENAI_API_KEY
              value: "${OPENAI_API_KEY}"
            - name: TELEPORT_IDENTITY_FILE
              value: /opt/machine-id/identity/identity
            - name: TELEPORT_PROXY
              value: "${TELEPORT_PROXY}:443"
          volumeMounts:
            - name: tbot-identity
              mountPath: /opt/machine-id/identity
              readOnly: true
          readinessProbe:
            httpGet:
              path: /.well-known/agent-card.json
              port: 8080
            initialDelaySeconds: 10
            periodSeconds: 5

        # --- tbot sidecar (keeps identity fresh for tsh ssh) ---
        - name: tbot
          image: public.ecr.aws/gravitational/tbot-distroless:18.6.4
          args:
            - start
            - -c
            - /etc/tbot/tbot.yaml
            - --diag-addr=0.0.0.0:3025
          env:
            - name: KUBERNETES_TOKEN_PATH
              value: /var/run/secrets/tokens/join-token
          volumeMounts:
            - name: tbot-config
              mountPath: /etc/tbot
            - name: tbot-storage
              mountPath: /opt/machine-id/storage
            - name: tbot-identity
              mountPath: /opt/machine-id/identity
            - name: join-sa-token
              mountPath: /var/run/secrets/tokens
              readOnly: true
          livenessProbe:
            httpGet:
              path: /livez
              port: 3025
          readinessProbe:
            httpGet:
              path: /readyz
              port: 3025

      volumes:
        - name: tbot-config
          configMap:
            name: agent-ssh-tbot-init-config
        - name: tbot-storage
          emptyDir: {}
        - name: tbot-identity
          emptyDir: {}
        - name: join-sa-token
          projected:
            sources:
              - serviceAccountToken:
                  audience: ${TELEPORT_PROXY}
                  expirationSeconds: 600
                  path: join-token
---
apiVersion: v1
kind: Service
metadata:
  name: agent-ssh
  namespace: ai-agents
  labels:
    teleport.expose: "true"
    app-type: specialist
    demo: ai-agents
spec:
  selector:
    demo: ai-agents
    function: agent-ssh
  ports:
    - port: 8080
      targetPort: 8080
