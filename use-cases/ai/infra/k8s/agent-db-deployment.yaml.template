apiVersion: v1
kind: ServiceAccount
metadata:
  name: agent-db-tbot
  namespace: ai-agents
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: agent-db
  namespace: ai-agents
spec:
  replicas: 1
  selector:
    matchLabels:
      demo: ai-agents
      function: agent-db
  template:
    metadata:
      labels:
        demo: ai-agents
        function: agent-db
    spec:
      serviceAccountName: agent-db-tbot
      # --- Init container: discover databases and generate tbot config ---
      initContainers:
        - name: discover-databases
          image: ${AGENT_DB_IMAGE}
          imagePullPolicy: IfNotPresent
          command: ["bash", "/scripts/discover-databases.sh"]
          env:
            - name: TELEPORT_PROXY
              value: "${TELEPORT_PROXY}:443"
            - name: TELEPORT_IDENTITY_FILE
              value: /opt/machine-id/identity/identity
            - name: TSH_DB_DISCOVERY_QUERY
              value: '${AGENT_DB_TSH_DISCOVERY_QUERY}'
            - name: TBOT_INIT_CONFIG
              value: /etc/tbot-init/tbot.yaml
            - name: TBOT_GENERATED_CONFIG
              value: /etc/tbot-generated/tbot.yaml
            - name: TBOT_JOIN_TOKEN
              value: agent-db-bot-k8s-join
            - name: DATABASES_JSON_PATH
              value: /etc/databases/databases.json
            - name: DEFAULT_DB_USER
              value: "bot-agent-db-bot"
            - name: DEFAULT_DB_NAME
              value: "demo"
            - name: KUBERNETES_TOKEN_PATH
              value: /var/run/secrets/tokens/join-token
          volumeMounts:
            - name: discover-script
              mountPath: /scripts
            - name: tbot-init-config
              mountPath: /etc/tbot-init
            - name: tbot-generated-config
              mountPath: /etc/tbot-generated
            - name: databases-config
              mountPath: /etc/databases
            - name: tbot-storage
              mountPath: /opt/machine-id/storage
            - name: tbot-identity
              mountPath: /opt/machine-id/identity
            - name: join-sa-token
              mountPath: /var/run/secrets/tokens
              readOnly: true

      containers:
        # --- Agent DB ---
        - name: agent-db
          image: ${AGENT_DB_IMAGE}
          imagePullPolicy: IfNotPresent
          command: ["python", "-m", "agents.agent_db.main"]
          ports:
            - containerPort: 8080
          env:
            - name: AGENT_PORT
              value: "8080"
            - name: LLM_PROVIDER
              value: "${LLM_PROVIDER}"
            - name: OPENAI_MODEL
              value: "${OPENAI_MODEL}"
            - name: OPENAI_BASE_URL
              value: "${OPENAI_BASE_URL}"
            - name: OPENAI_API_KEY
              value: "${OPENAI_API_KEY}"
            - name: DATABASES_CONFIG
              value: /etc/databases/databases.json
          volumeMounts:
            - name: databases-config
              mountPath: /etc/databases
              readOnly: true
          readinessProbe:
            httpGet:
              path: /.well-known/agent-card.json
              port: 8080
            initialDelaySeconds: 10
            periodSeconds: 5

        # --- tbot sidecar (runs database-tunnels from generated config) ---
        - name: tbot
          image: public.ecr.aws/gravitational/tbot-distroless:18.6.4
          args:
            - start
            - -c
            - /etc/tbot-generated/tbot.yaml
            - --diag-addr=0.0.0.0:3025
          env:
            - name: KUBERNETES_TOKEN_PATH
              value: /var/run/secrets/tokens/join-token
          volumeMounts:
            - name: tbot-generated-config
              mountPath: /etc/tbot-generated
            - name: tbot-storage
              mountPath: /opt/machine-id/storage
            - name: tbot-identity
              mountPath: /opt/machine-id/identity
            - name: join-sa-token
              mountPath: /var/run/secrets/tokens
              readOnly: true
          livenessProbe:
            httpGet:
              path: /livez
              port: 3025
          readinessProbe:
            httpGet:
              path: /readyz
              port: 3025

      volumes:
        - name: discover-script
          configMap:
            name: agent-db-discover-script
            defaultMode: 0755
        - name: tbot-init-config
          configMap:
            name: agent-db-tbot-init-config
        - name: tbot-generated-config
          emptyDir: {}
        - name: databases-config
          emptyDir: {}
        - name: tbot-storage
          emptyDir: {}
        - name: tbot-identity
          emptyDir: {}
        - name: join-sa-token
          projected:
            sources:
              - serviceAccountToken:
                  audience: ${TELEPORT_PROXY}
                  expirationSeconds: 600
                  path: join-token
---
apiVersion: v1
kind: Service
metadata:
  name: agent-db
  namespace: ai-agents
  labels:
    teleport.expose: "true"
    app-type: specialist
    demo: ai-agents
spec:
  selector:
    demo: ai-agents
    function: agent-db
  ports:
    - port: 8080
      targetPort: 8080
